# =============================================================================
# Context Manager — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# =============================================================================

# --- Server ---
PORT=3847
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/context_db
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000

# --- Qdrant (vector DB) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Embeddings (TEI) ---
EMBEDDING_PROVIDER=huggingface-tei
TEI_HOST=http://localhost:8080
EMBEDDING_DIMENSIONS=384

# --- Sync ---
SYNC_BATCH_SIZE=100
SYNC_INTERVAL_MS=60000

# --- Docker Compose only ---
# Path to ONNX model directory (mounted into tei-embeddings container)
# MODELS_DIR=./models
# Path to MCP adapter source (mounted into cm-mcp-adapter container)
# MCP_DIR=./mcp

# --- Advanced: config directory override ---
# Override the default config directory (~/.config/iflow on Linux,
# ~/Library/Application Support/iflow on macOS,
# %APPDATA%/iflow on Windows)
# CONFIG_DIR=
