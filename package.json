{
  "name": "context-manager",
  "version": "2.2.1",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Context management service for iFlow CLI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "TS_NODE_PROJECT=tsconfig.test.json node --require ts-node/register --test tests/*.test.ts",
    "tunnel:start": "python3 -m cm_integration.tunnel_manager",
    "bundle:api": "ncc build src/index.ts -o dist_bundle --minify",
    "bundle:mcp": "esbuild mcp/cm_http_adapter.mjs --bundle --platform=node --format=cjs --outfile=mcp/cm_http_adapter.bundle.js && esbuild mcp/server.js --bundle --platform=node --format=cjs --outfile=mcp/server.bundle.js",
    "bundle": "npm run bundle:api && npm run bundle:mcp"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@langchain/textsplitters": "^1.0.1",
    "@qdrant/js-client-rest": "^1.16.2",
    "@sinclair/typebox": "^0.32.0",
    "axios": "^1.13.2",
    "fastify": "^4.26.0",
    "pg": "^8.11.3",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@vercel/ncc": "^0.38.1",
    "esbuild": "^0.20.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
