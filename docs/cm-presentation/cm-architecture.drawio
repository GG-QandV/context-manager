    </mxCell>
    <mxCell id="l1c3" value="&lt;b&gt;Any MCP client&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Future/third-party AI tools (other AI tools)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d1b69;strokeColor=#7c3aed;fontColor=#c4b5fd;fontSize=12;" vertex="1" parent="l1">
      <mxGeometry x="730" y="50" width="190" height="60" as="geometry"/>
    </mxCell>

    <!-- LAYER 2 -->
    <mxCell id="l2" value="&lt;b&gt;LAYER 2 — CONTEXT MANAGER CORE (core)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Receives, processes, stores, and searches context — handles requests and manages context&lt;/font&gt;" style="swimlane;horizontal=0;startSize=140;fillColor=#0f172a;strokeColor=#3b82f6;fontColor=#60a5fa;fontStyle=1;html=1;rounded=1;" vertex="1" parent="1">
