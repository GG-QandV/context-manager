    </mxCell>
    <mxCell id="l2c0" value="&lt;b&gt;MCP Adapters&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Connection handlers — stdio + HTTP :8770&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e3a5f;strokeColor=#3b82f6;fontColor=#93c5fd;fontSize=12;" vertex="1" parent="l2">
      <mxGeometry x="130" y="48" width="220" height="64" as="geometry"/>
    </mxCell>
    <mxCell id="l2c2" value="&lt;b&gt;Fastify API Server (:3847)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;30+ commands · validation · logging&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e3a5f;strokeColor=#3b82f6;fontColor=#93c5fd;fontSize=12;" vertex="1" parent="l2">
      <mxGeometry x="430" y="48" width="340" height="64" as="geometry"/>
    </mxCell>

    <!-- LAYER 3 -->
    <mxCell id="l3" value="&lt;b&gt;LAYER 3 — STORAGE &amp;amp; ML (storage & ML)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Text database + meaning converter + vector database — text DB, meaning converter, vector DB&lt;/font&gt;" style="swimlane;horizontal=0;startSize=140;fillColor=#052e16;strokeColor=#10b981;fontColor=#34d399;fontStyle=1;html=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="360" width="1080" height="180" as="geometry"/>
