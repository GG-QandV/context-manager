<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Data Flow annotation -->
    <mxCell id="flow" value="Data flow (data flow): API → PostgreSQL (save text) → TEI Embedder (convert to meaning) → Qdrant (store vector). Both databases are auto-synced (both databases are synchronized)." style="text;html=1;fontSize=11;fontColor=#6b7280;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="80" y="555" width="940" height="30" as="geometry"/>
    </mxCell>

    <!-- LAYER 1 -->
    <mxCell id="l1" value="&lt;b&gt;LAYER 1 — INTEGRATIONS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;AI tools that connect to Context Manager — AI tools connect to the system&lt;/font&gt;" style="swimlane;horizontal=0;startSize=140;fillColor=#1a1a2e;strokeColor=#7c3aed;fontColor=#a78bfa;fontStyle=1;html=1;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="20" width="1080" height="150" as="geometry"/>
    </mxCell>
