    <mxCell id="e4" value="connects via HTTP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#7c3aed;fontColor=#a78bfa;" edge="1" parent="1" source="l1c3" target="l2c0">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGE: MCP adapters → API -->
    <mxCell id="e5" value="forwards to API :3847" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#3b82f6;fontColor=#60a5fa;" edge="1" parent="1" source="l2c0" target="l2c2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGE: API → PostgreSQL (step 1) -->
    <mxCell id="e6" value="1. save text (save text)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#10b981;fontColor=#34d399;" edge="1" parent="1" source="l2c2" target="l3c0">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGE: PostgreSQL → TEI (step 2) -->
    <mxCell id="e7" value="2. convert to meaning (convert to meaning)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#f59e0b;fontColor=#fcd34d;" edge="1" parent="1" source="l3c0" target="l3c2">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGE: TEI → Qdrant (step 3) -->
    <mxCell id="e8" value="3. store vector (store vector)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#f59e0b;fontColor=#fcd34d;" edge="1" parent="1" source="l3c2" target="l3c1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- EDGE: PostgreSQL ↔ Qdrant sync (bidirectional) -->
    <mxCell id="e9" value="auto-sync (same data in different formats)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#10b981;fontColor=#34d399;dashed=1;" edge="1" parent="1" source="l3c0" target="l3c1">
