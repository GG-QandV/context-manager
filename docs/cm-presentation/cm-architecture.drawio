    <mxCell id="l1c2" value="&lt;b&gt;iFlow CLI&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Terminal AI assistant&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d1b69;strokeColor=#7c3aed;fontColor=#c4b5fd;fontSize=12;" vertex="1" parent="l1">
