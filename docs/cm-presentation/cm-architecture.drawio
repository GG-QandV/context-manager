    <mxCell id="l3c0" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Text DB (text DB)&lt;br&gt;context_db · tsvector · GIN index · 526 rows&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#064e3b;strokeColor=#10b981;fontColor=#6ee7b7;fontSize=12;" vertex="1" parent="l3">
      <mxGeometry x="130" y="48" width="200" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="l3c1" value="&lt;b&gt;Qdrant&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Vector DB (vector DB)&lt;br&gt;1,336 points · 384d · Cosine&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#064e3b;strokeColor=#10b981;fontColor=#6ee7b7;fontSize=12;" vertex="1" parent="l3">
      <mxGeometry x="440" y="48" width="220" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="l3c2" value="&lt;b&gt;TEI Embedder&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Meaning converter (converter)&lt;br&gt;multilingual-e5-small · ONNX · 40 MB · ~15ms&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#422006;strokeColor=#f59e0b;fontColor=#fcd34d;fontSize=12;" vertex="1" parent="l3">
      <mxGeometry x="770" y="48" width="200" height="80" as="geometry"/>
    </mxCell>

    <!-- EDGES: integrations → MCP adapters -->
    <mxCell id="e1" value="connects via" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#7c3aed;fontColor=#a78bfa;" edge="1" parent="1" source="l1c0" target="l2c0">
