    <mxCell id="l1c1" value="&lt;b&gt;VS Code / Continue&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#999&quot;&gt;Code editor with AI (code editor with AI)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d1b69;strokeColor=#7c3aed;fontColor=#c4b5fd;fontSize=12;" vertex="1" parent="l1">
      <mxGeometry x="330" y="50" width="160" height="60" as="geometry"/>
